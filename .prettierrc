{
	"printWidth": 100,
	"semi": true,
	"singleQuote": true,
	"tabWidth": 4,
	"useTabs": true,
	"overrides": [
		{
			"files": ["**/*.css", "**/*.scss", "**/*.html"],
			"options": {
				"singleQuote": true
			}
		}
	],
	"trailingComma": "all",
	"bracketSpacing": true,
	"arrowParens": "always",
	"proseWrap": "never",
	"htmlWhitespaceSensitivity": "strict",
	"endOfLine": "lf",
	"singleAttributePerLine": true
}
